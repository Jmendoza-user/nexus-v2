# NEXUS V2.0 backend — variables de entorno (copiar a .env y rellenar)

# Conexión a la base de datos multi-tenant (NO usar la DB de Amparo ni la de V1)
DATABASE_URL=postgres://nexus_user:PASSWORD@127.0.0.1:5432/nexus_v2

# Secreto para firmar JWT (httpOnly cookie). Generar: openssl rand -hex 48
JWT_SECRET=

# Clave AES-256-GCM para cifrar tokens de connections (32 bytes hex = 64 chars).
# Generar: openssl rand -hex 32
ENCRYPTION_KEY=

# Puerto del API (3100 = V1, 3101 = frontend-mobile)
PORT=3110

# Raíz de datos aislados por usuario (DATA_DIR/users/user_NNNNNN_env/)
DATA_DIR=/root/nexus-v2/data

NODE_ENV=development
